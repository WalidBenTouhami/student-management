# ============================================================
# 📝 .env.example - Variables d'environnement (TEMPLATE)
# ============================================================
#
# ⚠️  CE FICHIER EST UN TEMPLATE - NE PAS UTILISER DIRECTEMENT
#
# 📌 UTILISATION :
#   1. Copiez ce fichier vers .env
#   2. Adaptez les valeurs pour votre environnement
#   3. Ne commitez JAMAIS le fichier .env
#
# 🔒 LES SECRETS NE SONT JAMAIS COMMITÉS
# ============================================================

# ============================================================
# 🌐 CONFIGURATION GÉNÉRALE
# ============================================================

# Environnement (dev, test, staging, prod)
ENVIRONMENT=dev

# Nom du projet
PROJECT_NAME=student-management

# Domaine/URL de l'application
APP_DOMAIN=student-management.local
APP_URL=http://localhost:8089

# ============================================================
# 🔧 SPRING BOOT CONFIGURATION
# ============================================================

# Port du serveur
SERVER_PORT=8089

# Contexte de l'application
SERVER_CONTEXT_PATH=/student

# Profil actif (dev, test, prod)
SPRING_PROFILES_ACTIVE=dev

# Configuration JPA
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_DDL_AUTO=validate
SPRING_JPA_FORMAT_SQL=true
SPRING_JPA_DIALECT=org.hibernate.dialect.MySQL8Dialect

# ============================================================
# 🐬 BASE DE DONNÉES MYSQL
# ============================================================

# URL de connexion (avec paramètres JDBC)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/studentdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Identifiants
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_me

# Authentification HTTP Basic de l'API
APP_SECURITY_USERNAME=api-user
APP_SECURITY_PASSWORD=change_me

# Origines CORS, séparées par des virgules
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# Utilisateur application
MYSQL_USER=spring
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me

# ============================================================
# 📊 JENKINS CONFIGURATION
# ============================================================

# URL de Jenkins
JENKINS_URL=http://localhost:8080

# Identifiants Jenkins
JENKINS_USER=admin
JENKINS_PASSWORD=change_me

# Token API Jenkins (généré dans Jenkins)
JENKINS_API_TOKEN=change_me

# Plugin Prometheus pour Jenkins
JENKINS_METRICS_PATH=/prometheus

# ============================================================
# 📈 SONARQUBE CONFIGURATION
# ============================================================

# URL de SonarQube
SONAR_HOST_URL=http://localhost:9000

# Identifiants SonarQube
SONAR_LOGIN=admin
SONAR_PASSWORD=change_me

# Token SonarQube (généré dans SonarQube)
SONAR_TOKEN=change_me

# Clé du projet SonarQube
SONAR_PROJECT_KEY=student-management
SONAR_PROJECT_NAME=Student Management
SONAR_PROJECT_VERSION=1.0.0

# Langages à analyser
SONAR_LANGUAGE=java
SONAR_SOURCES=src/main/java
SONAR_TEST_SOURCES=src/test/java
SONAR_JAVA_BINARIES=target/classes
SONAR_JAVA_TEST_BINARIES=target/test-classes

# ============================================================
# 🐳 DOCKER CONFIGURATION
# ============================================================

# Docker Hub
DOCKER_USERNAME=change_me
DOCKER_PASSWORD=change_me
DOCKER_EMAIL=change_me@example.com

# Image Docker
DOCKER_IMAGE_NAME=student-management
DOCKER_IMAGE_TAG=latest
DOCKER_REGISTRY=docker.io
DOCKER_REPOSITORY=${DOCKER_REGISTRY}/${DOCKER_USERNAME}/${DOCKER_IMAGE_NAME}

# Docker Compose
DOCKER_COMPOSE_FILE=docker-compose.yml
DOCKER_COMPOSE_PROJECT=devops

# ============================================================
# ☸️ KUBERNETES CONFIGURATION
# ============================================================

# Namespace
K8S_NAMESPACE=devops

# Déploiement
K8S_DEPLOYMENT_NAME=spring-app
K8S_SERVICE_NAME=spring-service
K8S_CONTAINER_PORT=8080
K8S_NODE_PORT=30080

# Replicas
K8S_REPLICAS=2

# Image
K8S_IMAGE=${DOCKER_REPOSITORY}:${DOCKER_IMAGE_TAG}

# ============================================================
# 📉 PROMETHEUS & GRAFANA
# ============================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_URL=http://localhost:9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me

# Dashboard ID pour Grafana (Jenkins: 9964)
GRAFANA_DASHBOARD_ID=9964

# ============================================================
# 🔐 SECURITÉ
# ============================================================

# JWT Secret (générer avec: openssl rand -base64 32)
JWT_SECRET=change_me_generate_random_secret

# Spring Boot Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus,metrics
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# ============================================================
# 📧 EMAIL CONFIGURATION (optionnel)
# ============================================================

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change_me@example.com
MAIL_PASSWORD=change_me
MAIL_PROTOCOL=smtp
MAIL_TLS_ENABLED=true
MAIL_AUTH_ENABLED=true

# ============================================================
# 📱 LOGGING
# ============================================================

# Niveau de log
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN

# Fichier de log
LOGGING_FILE_NAME=logs/application.log
LOGGING_FILE_MAX_SIZE=10MB
LOGGING_FILE_MAX_HISTORY=30

# Pattern de log
LOGGING_PATTERN_CONSOLE=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
LOGGING_PATTERN_FILE=%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n

# ============================================================
# 🗄️ RESSOURCES (Java)
# ============================================================

# Java Memory
JAVA_OPTS=-Xms512m -Xmx2048m -XX:+UseG1GC

# Spring Boot
SPRING_MAIN_BANNER_MODE=off

# ============================================================
# 🌍 AUTRES VARIABLES
# ============================================================

# Timezone
TZ=UTC

# Langue
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8

# ============================================================
# 📝 INSTRUCTIONS
# ============================================================
#
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplacer 'change_me' par vos vraies valeurs
# 3. Jamais commiter le fichier .env
# 4. Utiliser les variables avec ${VAR_NAME}
#
# Pour générer une clé JWT aléatoire :
# openssl rand -base64 32
#
# Pour générer un mot de passe sécurisé :
# openssl rand -base64 16
# ============================================================
